@model IEnumerable<NetworkMonitoringSystem.Web.Models.UserViewModel>

@{
    ViewData["Title"] = "User Management";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <p class="text-muted mb-0">Manage system users and access control</p>
    </div>
    <a asp-action="Create" class="btn btn-primary fw-medium shadow-sm">
        <i class="fa-solid fa-user-plus me-2"></i> Add User
    </a>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">Name</th>
                        <th>Email</th>
                        <th>Role</th>
                        <th>Status</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                <div class="d-flex align-items-center">
                                    <img src="https://ui-avatars.com/api/?name=@user.FullName&background=random" class="rounded-circle me-3" width="40" height="40" alt="@user.FullName">
                                    <h6 class="mb-0 fw-bold">@user.FullName</h6>
                                </div>
                            </td>
                            <td>@user.Email</td>
                            <td>
                                @foreach (var role in user.Roles)
                                {
                                    <span class="badge bg-primary text-white rounded-pill px-3 py-2">@role</span>
                                }
                            </td>
                            <td>
                                @if(user.IsActive) {
                                    <span class="badge bg-success bg-opacity-10 text-success border border-success-subtle px-2 py-1"><i class="fa-solid fa-check-circle me-1"></i>Active</span>
                                } else {
                                    <span class="badge bg-danger bg-opacity-10 text-danger border border-danger-subtle px-2 py-1"><i class="fa-solid fa-xmark-circle me-1"></i>Inactive</span>
                                }
                            </td>
                            <td class="text-end pe-4">
                                <div class="d-flex align-items-center justify-content-end gap-2">
                                    <form asp-action="ToggleStatus" asp-route-id="@user.Id" method="post" style="display:inline;">
                                        @if (user.IsActive)
                                        {
                                            <button type="submit" class="btn btn-sm btn-outline-success" @(user.Email == User.Identity?.Name ? "disabled" : "") title="Active — Click to Disable">
                                                <i class="fa-solid fa-toggle-on"></i>
                                            </button>
                                        }
                                        else
                                        {
                                            <button type="submit" class="btn btn-sm btn-outline-secondary" title="Inactive — Click to Enable">
                                                <i class="fa-solid fa-toggle-off"></i>
                                            </button>
                                        }
                                    </form>
                                    <a href="#" class="btn btn-sm btn-light border" title="Edit">
                                        <i class="fa-solid fa-pen text-muted"></i>
                                    </a>
                                    @if (user.Email != User.Identity?.Name)
                                    {
                                        <a href="#" class="btn btn-sm btn-light border" title="Delete">
                                            <i class="fa-solid fa-trash text-danger"></i>
                                        </a>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
