@model NetworkMonitoringSystem.Web.Models.LoginViewModel
@{
    ViewData["Title"] = "Sign In";
    Layout = "_Layout";
}

<div class="auth-wrapper">
    <div class="auth-card">

        <!-- Brand -->
        <div class="text-center mb-4">
            <div class="d-inline-flex align-items-center justify-content-center mb-3"
                 style="width:56px;height:56px;border-radius:16px;
                        background:linear-gradient(135deg,#6366f1,#4338ca);
                        box-shadow:0 8px 24px rgba(99,102,241,0.45);">
                <i class="fa-solid fa-network-wired" style="color:#fff;font-size:1.4rem;"></i>
            </div>
            <h4 style="color:#fff;font-weight:800;letter-spacing:-0.03em;margin:0;">NMS Enterprise</h4>
            <p style="color:rgba(255,255,255,0.4);font-size:0.82rem;margin:4px 0 0;">Sign in to access your dashboard</p>
        </div>

        <form asp-controller="Account" asp-action="Login" asp-route-returnurl='@ViewData["ReturnUrl"]' method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3" style="font-size:0.8rem;"></div>

            <div class="mb-3">
                <label asp-for="Email" class="form-label">Email address</label>
                <div class="input-group">
                    <span class="input-group-text border-end-0">
                        <i class="fa-regular fa-envelope"></i>
                    </span>
                    <input asp-for="Email"
                           class="form-control border-start-0 ps-0"
                           placeholder="name@company.com"
                           autocomplete="email" />
                </div>
                <span asp-validation-for="Email" class="text-danger" style="font-size:0.75rem;"></span>
            </div>

            <div class="mb-4">
                <div class="d-flex justify-content-between align-items-center mb-1">
                    <label asp-for="Password" class="form-label mb-0">Password</label>
                    <a href="#" style="font-size:0.75rem;color:var(--brand-400);text-decoration:none;">Forgot password?</a>
                </div>
                <div class="input-group">
                    <span class="input-group-text border-end-0">
                        <i class="fa-solid fa-lock"></i>
                    </span>
                    <input asp-for="Password"
                           class="form-control border-start-0 ps-0"
                           placeholder="••••••••"
                           autocomplete="current-password" />
                </div>
                <span asp-validation-for="Password" class="text-danger" style="font-size:0.75rem;"></span>
            </div>

            <div class="mb-4 d-flex align-items-center gap-2">
                <input asp-for="RememberMe" class="form-check-input mt-0" style="width:1em;height:1em;" />
                <label asp-for="RememberMe" class="form-check-label" style="font-size:0.8rem;color:rgba(255,255,255,0.5);">
                    Keep me signed in
                </label>
            </div>

            <button type="submit" class="btn btn-primary w-100 py-2"
                    style="font-weight:700;font-size:0.9rem;letter-spacing:0.01em;">
                Sign In <i class="fa-solid fa-arrow-right ms-1"></i>
            </button>
        </form>

        <div class="text-center mt-4" style="font-size:0.72rem;color:rgba(255,255,255,0.2);">
            &copy; 2026 Network Monitoring System
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
