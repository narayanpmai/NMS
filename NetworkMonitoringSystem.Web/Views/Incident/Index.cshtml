@model IEnumerable<NetworkMonitoringSystem.Domain.Entities.Incident>
@{
    ViewData["Title"] = "Incident Management";
    var users = ViewBag.Users as IEnumerable<NetworkMonitoringSystem.Infrastructure.Identity.ApplicationUser>
                ?? new List<NetworkMonitoringSystem.Infrastructure.Identity.ApplicationUser>();
    var currentFilter = ViewBag.StatusFilter as string ?? "Active";
}

<div class="page-header mb-4">
    <div>
        <h5>Incident Management Queue</h5>
        <p>Track, assign, resolve, and audit system threshold incidents</p>
    </div>
    <div class="d-flex gap-2 flex-wrap">
        @foreach (var f in new[] { "Active", "Open", "Resolved", "Closed", "All" })
        {
            <a href="?statusFilter=@f"
               class="btn btn-sm @(currentFilter == f ? "btn-primary" : "btn-outline-primary")">
                @f
            </a>
        }
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="d-flex align-items-center gap-2 p-3 mb-3 rounded-2"
         style="background:#f0fdf4;border:1px solid #bbf7d0;color:#15803d;font-size:0.82rem;font-weight:500;">
        <i class="fa-solid fa-circle-check"></i> @TempData["SuccessMessage"]
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="d-flex align-items-center gap-2 p-3 mb-3 rounded-2"
         style="background:#fef2f2;border:1px solid #fecaca;color:#dc2626;font-size:0.82rem;font-weight:500;">
        <i class="fa-solid fa-circle-exclamation"></i> @TempData["ErrorMessage"]
    </div>
}

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table">
                <thead>
                    <tr>
                        <th style="padding-left:1.5rem;width:70px;">ID</th>
                        <th>Incident</th>
                        <th>Device</th>
                        <th>Severity</th>
                        <th>Status</th>
                        <th>Assigned To</th>
                        <th>Created</th>
                        <th style="text-align:right;padding-right:1.5rem;width:180px;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="8">
                                <div class="empty-state">
                                    <div class="empty-icon"><i class="fa-solid fa-inbox"></i></div>
                                    <h6>No incidents found</h6>
                                    <p>All network devices are performing within normal parameters.</p>
                                </div>
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var incident in Model)
                        {
                            var sevClass = incident.Severity == "Critical" ? "badge-critical"
                                         : incident.Severity == "Warning"  ? "badge-warning"
                                         : "badge-info";

                            var statusClass = incident.Status switch
                            {
                                "Open"        => "badge-neutral",
                                "Assigned"    => "badge-info",
                                "In Progress" => "badge-info",
                                "Resolved"    => "badge-success",
                                "Closed"      => "badge-neutral",
                                _             => "badge-neutral"
                            };

                            <tr>
                                <td style="padding-left:1.5rem;">
                                    <span class="font-mono" style="font-size:0.78rem;font-weight:700;color:var(--gray-400);">#@incident.Id</span>
                                </td>
                                <td>
                                    <div style="font-size:0.82rem;font-weight:700;color:var(--gray-900);">@incident.Title</div>
                                    <div style="font-size:0.72rem;color:var(--gray-400);max-width:300px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
                                        @incident.Description
                                    </div>
                                    @if (incident.Status == "Resolved" && !string.IsNullOrEmpty(incident.RootCause))
                                    {
                                        <div class="mt-1 p-2 rounded-1" style="background:#f0fdf4;border-left:3px solid var(--color-success);font-size:0.72rem;color:#15803d;">
                                            <strong>Root Cause:</strong> @incident.RootCause
                                        </div>
                                    }
                                </td>
                                <td>
                                    @if (incident.Device != null)
                                    {
                                        <div style="font-size:0.8rem;font-weight:600;color:var(--gray-800);">@incident.Device.Name</div>
                                        <span class="font-mono badge-neutral badge">@incident.Device.IPAddress</span>
                                    }
                                    else
                                    {
                                        <span style="font-size:0.78rem;color:var(--gray-400);">Global</span>
                                    }
                                </td>
                                <td><span class="badge @sevClass">@incident.Severity</span></td>
                                <td><span class="badge @statusClass">@incident.Status</span></td>
                                <td>
                                    @if (string.IsNullOrEmpty(incident.AssignedToUserId))
                                    {
                                        <span style="font-size:0.78rem;color:var(--gray-300);">Unassigned</span>
                                    }
                                    else
                                    {
                                        var assignedUser = users.FirstOrDefault(u => u.Id == incident.AssignedToUserId);
                                        <span style="font-size:0.8rem;font-weight:600;color:var(--gray-700);">
                                            <i class="fa-solid fa-user-check me-1" style="color:var(--brand-500);font-size:0.7rem;"></i>
                                            @(assignedUser?.FullName ?? "Unknown")
                                        </span>
                                    }
                                </td>
                                <td>
                                    <div class="font-mono" style="font-size:0.72rem;color:var(--gray-400);">
                                        @incident.CreatedAt.ToString("yyyy-MM-dd HH:mm")
                                    </div>
                                </td>
                                <td style="text-align:right;padding-right:1.5rem;">
                                    <div class="d-flex justify-content-end gap-1">
                                        @if (incident.Status == "Open" || string.IsNullOrEmpty(incident.AssignedToUserId))
                                        {
                                            <form asp-action="AssignToSelf" method="post" class="d-inline">
                                                <input type="hidden" name="incidentId" value="@incident.Id" />
                                                <button type="submit" class="btn btn-sm btn-outline-primary">
                                                    <i class="fa-solid fa-user-plus"></i> Assign
                                                </button>
                                            </form>
                                        }
                                        @if (incident.Status != "Resolved" && incident.Status != "Closed")
                                        {
                                            <button type="button" class="btn btn-sm btn-outline-success"
                                                    onclick="openResolveModal(@incident.Id, '@incident.Title.Replace("'", "\\'")' )">
                                                <i class="fa-solid fa-check"></i> Resolve
                                            </button>
                                        }
                                        @if (incident.Status == "Resolved")
                                        {
                                            <form asp-action="Close" method="post" class="d-inline">
                                                <input type="hidden" name="incidentId" value="@incident.Id" />
                                                <button type="submit" class="btn btn-sm"
                                                        style="background:var(--gray-800);color:#fff;border-color:var(--gray-800);">
                                                    <i class="fa-solid fa-box-archive"></i> Close
                                                </button>
                                            </form>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Resolve Modal -->
<div class="modal fade" id="resolveModal" tabindex="-1" aria-labelledby="resolveModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content" style="border:1px solid var(--gray-200);border-radius:var(--radius-lg);box-shadow:var(--shadow-xl);">
            <form asp-action="Resolve" method="post">
                <div class="modal-header" style="border-bottom:1px solid var(--gray-100);padding:1.25rem 1.5rem;">
                    <h6 class="modal-title fw-bold" id="resolveModalLabel" style="color:var(--gray-900);">
                        <i class="fa-solid fa-check-circle me-2" style="color:var(--color-success);"></i>Resolve Incident
                    </h6>
                    <button type="button" class="btn-close btn-sm" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body" style="padding:1.5rem;">
                    <input type="hidden" name="incidentId" id="resolveIncidentId" />
                    <div class="mb-3">
                        <label class="form-label">Incident</label>
                        <input type="text" id="resolveIncidentTitle" class="form-control"
                               style="background:var(--gray-50);color:var(--gray-500);" readonly />
                    </div>
                    <div class="mb-3">
                        <label for="rootCause" class="form-label">Root Cause / Resolution Notes <span style="color:var(--color-danger);">*</span></label>
                        <textarea class="form-control" name="rootCause" id="rootCause" rows="4"
                                  placeholder="Explain the root cause and steps taken to resolve this threshold breach..."
                                  required></textarea>
                    </div>
                </div>
                <div class="modal-footer" style="border-top:1px solid var(--gray-100);padding:1rem 1.5rem;">
                    <button type="button" class="btn btn-outline-primary btn-sm" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary btn-sm">
                        <i class="fa-solid fa-check-double me-1"></i> Submit Resolution
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
    function openResolveModal(id, title) {
        document.getElementById('resolveIncidentId').value    = id;
        document.getElementById('resolveIncidentTitle').value = title;
        document.getElementById('rootCause').value            = '';
        new bootstrap.Modal(document.getElementById('resolveModal')).show();
    }
</script>
}
