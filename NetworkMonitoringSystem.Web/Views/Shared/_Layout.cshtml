<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - NMS Dashboard</title>
    <meta name="description" content="Enterprise Network Monitoring System - Real-time device monitoring, alerts, and reporting." />

    <!-- Preconnect for performance -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Font Awesome 6 -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">

    <!-- Custom Design System -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/NetworkMonitoringSystem.Web.styles.css" asp-append-version="true" />
</head>
<body>
    @if (User?.Identity?.IsAuthenticated == true)
    {
        <!-- Sidebar -->
        <nav class="sidebar">
            <a href="/" class="sidebar-brand text-decoration-none">
                <div class="sidebar-brand-icon">
                    <i class="fa-solid fa-network-wired" style="color:#fff;"></i>
                </div>
                <div class="sidebar-brand-text">
                    <strong>NMS Admin</strong>
                    <span>Enterprise Monitor</span>
                </div>
            </a>

            <div class="mt-1 overflow-auto" style="flex:1;">
                <div class="sidebar-section-label">Monitor</div>
                <ul class="nav flex-column px-0">
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" && ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")"
                           asp-controller="Home" asp-action="Index">
                            <div class="nav-icon"><i class="fa-solid fa-chart-line fa-fw"></i></div>
                            Overview
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" && ViewContext.RouteData.Values["action"]?.ToString() == "Topology" ? "active" : "")"
                           asp-controller="Home" asp-action="Topology">
                            <div class="nav-icon"><i class="fa-solid fa-circle-nodes fa-fw"></i></div>
                            Topology
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" && ViewContext.RouteData.Values["action"]?.ToString() == "Map" ? "active" : "")"
                           asp-controller="Home" asp-action="Map">
                            <div class="nav-icon"><i class="fa-solid fa-map-location-dot fa-fw"></i></div>
                            GIS Map
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-muted" href="#">
                            <div class="nav-icon"><i class="fa-solid fa-wifi fa-fw"></i></div>
                            Wireless / APs <span class="badge bg-secondary ms-auto" style="font-size:0.5rem">PRO</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-muted" href="#">
                            <div class="nav-icon"><i class="fa-solid fa-laptop fa-fw"></i></div>
                            Clients <span class="badge bg-secondary ms-auto" style="font-size:0.5rem">PRO</span>
                        </a>
                    </li>
                </ul>

                <div class="sidebar-section-label">Configuration</div>
                <ul class="nav flex-column px-0">
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Device" && ViewContext.RouteData.Values["action"]?.ToString() != "Discover" ? "active" : "")"
                           asp-controller="Device" asp-action="Index">
                            <div class="nav-icon"><i class="fa-solid fa-server fa-fw"></i></div>
                            Device Management
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Discover" ? "active" : "")"
                           asp-controller="Device" asp-action="Discover">
                            <div class="nav-icon"><i class="fa-solid fa-magnifying-glass fa-fw"></i></div>
                            Discovery
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Project" ? "active" : "")" 
                           asp-controller="Project" asp-action="Index">
                            <div class="nav-icon"><i class="fa-solid fa-folder-tree fa-fw"></i></div>
                            Project Management
                        </a>
                    </li>
                </ul>

                <div class="sidebar-section-label">Maintenance</div>
                <ul class="nav flex-column px-0">
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Alert" ? "active" : "")"
                           asp-controller="Alert" asp-action="Index">
                            <div class="nav-icon"><i class="fa-solid fa-bell fa-fw"></i></div>
                            Alarms
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Incident" ? "active" : "")"
                           asp-controller="Incident" asp-action="Index">
                            <div class="nav-icon"><i class="fa-solid fa-ticket fa-fw"></i></div>
                            Incidents & Tickets
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "ISP" ? "active" : "")"
                           asp-controller="ISP" asp-action="Index">
                            <div class="nav-icon"><i class="fa-solid fa-tower-broadcast fa-fw"></i></div>
                            ISP Status
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "ServerResource" ? "active" : "")"
                           asp-controller="ServerResource" asp-action="Index">
                            <div class="nav-icon"><i class="fa-solid fa-microchip fa-fw"></i></div>
                            Server Diagnostics
                        </a>
                    </li>
                </ul>

                <div class="sidebar-section-label">Analytics</div>
                <ul class="nav flex-column px-0">
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Report" ? "active" : "")"
                           asp-controller="Report" asp-action="Index">
                            <div class="nav-icon"><i class="fa-solid fa-chart-pie fa-fw"></i></div>
                            Reports
                        </a>
                    </li>
                </ul>

                @if (User.IsInRole("Super Admin"))
                {
                    <div class="sidebar-section-label">System</div>
                    <ul class="nav flex-column px-0">
                        <li class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "User" ? "active" : "")"
                               asp-controller="User" asp-action="Index">
                                <div class="nav-icon"><i class="fa-solid fa-users-gear fa-fw"></i></div>
                                User Management
                            </a>
                        </li>
                    </ul>
                }
            </div>

            <div class="sidebar-footer">
                &copy; 2026 Network Monitoring System
            </div>
        </nav>

        <!-- Main Content -->
        <div class="main-content">
            <!-- Top Header -->
            <header class="top-header">
                <div>
                    <div class="page-title">@ViewData["Title"]</div>
                </div>
                <div class="d-flex align-items-center gap-3">
                    <!-- Live Status Indicator -->
                    <div class="d-flex align-items-center gap-2 px-3 py-1 rounded-pill"
                         style="background:var(--gray-100); font-size:0.72rem; font-weight:600; color:var(--color-success);">
                        <span class="live-dot"></span>
                        System Live
                    </div>

                    <!-- User Dropdown -->
                    <div class="dropdown">
                        <a href="#" class="header-user-btn dropdown-toggle text-decoration-none" data-bs-toggle="dropdown" aria-expanded="false">
                            <img src="https://ui-avatars.com/api/?name=@Uri.EscapeDataString(User.Identity?.Name ?? "User")&background=6366f1&color=fff&bold=true&size=60"
                                 class="header-avatar" width="30" height="30" alt="User Avatar">
                            <span class="header-user-name">@User.Identity?.Name</span>
                            <i class="fa-solid fa-chevron-down" style="font-size:0.6rem; color:var(--gray-400);"></i>
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li>
                                <a class="dropdown-item" href="#">
                                    <i class="fa-regular fa-user"></i> Profile
                                </a>
                            </li>
                            <li><hr class="dropdown-divider"></li>
                            <li>
                                <form method="post" asp-controller="Account" asp-action="Logout">
                                    <button type="submit" class="dropdown-item text-danger">
                                        <i class="fa-solid fa-right-from-bracket"></i> Sign Out
                                    </button>
                                </form>
                            </li>
                        </ul>
                    </div>
                </div>
            </header>

            <!-- Page Content -->
            <div class="content-body">
                @RenderBody()
            </div>

            <!-- Footer -->
            <footer class="footer mt-auto">
                <span>&copy; 2026 Network Monitoring System. All rights reserved.</span>
                <span class="d-flex align-items-center gap-2">
                    <span class="live-dot" style="width:6px;height:6px;"></span>
                    All systems operational
                </span>
            </footer>
        </div>
    }
    else
    {
        @RenderBody()
    }

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
