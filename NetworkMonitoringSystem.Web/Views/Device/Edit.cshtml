@model NetworkMonitoringSystem.Domain.Entities.Device
@{
    ViewData["Title"] = "Edit Device";
    var types    = ViewBag.DeviceTypes    as IEnumerable<NetworkMonitoringSystem.Domain.Entities.DeviceType>    ?? new List<NetworkMonitoringSystem.Domain.Entities.DeviceType>();
    var statuses = ViewBag.DeviceStatuses as IEnumerable<NetworkMonitoringSystem.Domain.Entities.DeviceStatus> ?? new List<NetworkMonitoringSystem.Domain.Entities.DeviceStatus>();
}

<div class="page-header mb-4">
    <div>
        <h5>Edit Device</h5>
        <p>Update configuration for <strong>@Model.Name</strong></p>
    </div>
    <a asp-action="Index" class="btn btn-outline-primary btn-sm">
        <i class="fa-solid fa-arrow-left me-1"></i> Back to Devices
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-12 col-lg-8">
        <div class="card">
            <div class="card-header">
                <div class="d-flex align-items-center gap-3">
                    <div class="icon-box">
                        <i class="fa-solid @(Model.DeviceType?.Icon ?? "fa-server") fa-fw"></i>
                    </div>
                    <div>
                        <h6 class="card-title">@Model.Name</h6>
                        <div style="font-size:0.72rem;color:var(--gray-400);" class="font-mono">@Model.IPAddress</div>
                    </div>
                </div>
            </div>
            <div class="card-body">
                <form asp-action="Edit" method="post">
                    <input type="hidden" asp-for="Id" />
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3" style="font-size:0.8rem;"></div>

                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label asp-for="Name" class="form-label">Device Name <span style="color:var(--color-danger);">*</span></label>
                            <input asp-for="Name" class="form-control" />
                            <span asp-validation-for="Name" class="text-danger" style="font-size:0.75rem;"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Hostname" class="form-label">Hostname</label>
                            <input asp-for="Hostname" class="form-control font-mono" />
                        </div>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label asp-for="IPAddress" class="form-label">IP Address <span style="color:var(--color-danger);">*</span></label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fa-solid fa-network-wired"></i></span>
                                <input asp-for="IPAddress" class="form-control font-mono" />
                            </div>
                            <span asp-validation-for="IPAddress" class="text-danger" style="font-size:0.75rem;"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="MacAddress" class="form-label">MAC Address</label>
                            <input asp-for="MacAddress" class="form-control font-mono" />
                        </div>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label asp-for="DeviceTypeId" class="form-label">Device Type</label>
                            <select asp-for="DeviceTypeId" class="form-select">
                                @foreach (var t in types)
                                {
                                    <option value="@t.Id" selected="@(t.Id == Model.DeviceTypeId ? "selected" : null)">@t.Name</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="StatusId" class="form-label">Status</label>
                            <select asp-for="StatusId" class="form-select">
                                @foreach (var s in statuses)
                                {
                                    <option value="@s.Id" selected="@(s.Id == Model.StatusId ? "selected" : null)">@s.Name</option>
                                }
                            </select>
                        </div>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label asp-for="Vendor" class="form-label">Vendor</label>
                            <input asp-for="Vendor" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Model" class="form-label">Model</label>
                            <input asp-for="Model" class="form-control" />
                        </div>
                    </div>

                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <label asp-for="Location" class="form-label">Location</label>
                            <input asp-for="Location" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Department" class="form-label">Department</label>
                            <input asp-for="Department" class="form-control" />
                        </div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="fa-solid fa-floppy-disk me-1"></i> Save Changes
                        </button>
                        <a asp-action="Index" class="btn btn-outline-primary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
