@model IEnumerable<NetworkMonitoringSystem.Domain.Entities.Device>
@{
    ViewData["Title"] = "Devices";
}

<div class="page-header mb-4">
    <div>
        <h5>Managed Devices</h5>
        <p>All registered and monitored network assets</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Discover" class="btn btn-outline-primary btn-sm">
            <i class="fa-solid fa-satellite-dish me-1"></i> Discover
        </a>
        <a asp-action="Create" class="btn btn-primary btn-sm">
            <i class="fa-solid fa-plus me-1"></i> Add Device
        </a>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="d-flex align-items-center gap-2 p-3 mb-3 rounded-2"
         style="background:#f0fdf4;border:1px solid #bbf7d0;color:#15803d;font-size:0.82rem;font-weight:500;">
        <i class="fa-solid fa-circle-check"></i> @TempData["SuccessMessage"]
    </div>
}

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table">
                <thead>
                    <tr>
                        <th style="padding-left:1.5rem;">Device</th>
                        <th>IP Address</th>
                        <th>Type</th>
                        <th>Status</th>
                        <th>Vendor / Model</th>
                        <th>Location</th>
                        <th style="text-align:right;padding-right:1.5rem;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="7">
                                <div class="empty-state">
                                    <div class="empty-icon"><i class="fa-solid fa-server"></i></div>
                                    <h6>No devices registered</h6>
                                    <p>Use <strong>Discover</strong> to auto-detect devices or <strong>Add Device</strong> manually.</p>
                                </div>
                            </td>
                        </tr>
                    }
                    @foreach (var device in Model)
                    {
                        string statusName = device.Status?.Name ?? "Unknown";
                        string statusClass = statusName == "Online"  ? "status-online"
                                           : statusName == "Offline" ? "status-offline"
                                           : "status-warning";
                        <tr>
                            <td style="padding-left:1.5rem;">
                                <div class="d-flex align-items-center gap-3">
                                    <div class="icon-box">
                                        <i class="fa-solid @(device.DeviceType?.Icon ?? "fa-server") fa-fw"></i>
                                    </div>
                                    <div>
                                        <div style="font-size:0.82rem;font-weight:700;color:var(--gray-900);">@device.Name</div>
                                        <div style="font-size:0.72rem;color:var(--gray-400);">@device.Hostname</div>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <span class="font-mono badge-neutral badge">@device.IPAddress</span>
                            </td>
                            <td style="font-size:0.8rem;color:var(--gray-500);">@(device.DeviceType?.Name ?? "—")</td>
                            <td>
                                <span class="status-badge @statusClass">
                                    <span class="dot"></span>
                                    @statusName
                                </span>
                            </td>
                            <td>
                                <div style="font-size:0.78rem;font-weight:600;color:var(--gray-700);">@(device.Vendor ?? "—")</div>
                                <div style="font-size:0.72rem;color:var(--gray-400);">@(device.Model ?? "—")</div>
                            </td>
                            <td style="font-size:0.78rem;color:var(--gray-500);">@(device.Location ?? "—")</td>
                            <td style="text-align:right;padding-right:1.5rem;">
                                <div class="d-flex align-items-center justify-content-end gap-2">
                                    @* Enable / Disable Monitoring Toggle *@
                                    <form asp-action="ToggleMonitoring" asp-route-id="@device.Id" method="post" style="display:inline;">
                                        @if (device.IsMonitoringEnabled)
                                        {
                                            <button type="submit" class="btn btn-sm btn-outline-success" title="Monitoring is ON — Click to Disable">
                                                <i class="fa-solid fa-toggle-on me-1"></i> Enabled
                                            </button>
                                        }
                                        else
                                        {
                                            <button type="submit" class="btn btn-sm btn-outline-secondary" title="Monitoring is OFF — Click to Enable">
                                                <i class="fa-solid fa-toggle-off me-1"></i> Disabled
                                            </button>
                                        }
                                    </form>

                                    @* Edit *@
                                    <a asp-action="Edit" asp-route-id="@device.Id"
                                       class="btn btn-sm btn-outline-primary" title="Edit Device">
                                        <i class="fa-solid fa-pen me-1"></i> Edit
                                    </a>

                                    @* Delete *@
                                    <form asp-action="Delete" asp-route-id="@device.Id" method="post" style="display:inline;"
                                          onsubmit="return confirm('Are you sure you want to delete device \'@device.Name\'? All alerts and metrics for this device will also be removed.');">
                                        <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete Device">
                                            <i class="fa-solid fa-trash me-1"></i> Delete
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
