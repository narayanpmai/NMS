@model NetworkMonitoringSystem.Domain.Entities.Device
@{
    ViewData["Title"] = "Add Device";
    var types    = ViewBag.DeviceTypes    as IEnumerable<NetworkMonitoringSystem.Domain.Entities.DeviceType>    ?? new List<NetworkMonitoringSystem.Domain.Entities.DeviceType>();
    var statuses = ViewBag.DeviceStatuses as IEnumerable<NetworkMonitoringSystem.Domain.Entities.DeviceStatus> ?? new List<NetworkMonitoringSystem.Domain.Entities.DeviceStatus>();
}

<div class="page-header mb-4">
    <div>
        <h5>Add New Device</h5>
        <p>Register a new network asset for monitoring</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-primary btn-sm">
        <i class="fa-solid fa-arrow-left me-1"></i> Back to Devices
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-12 col-lg-8">
        <div class="card">
            <div class="card-header">
                <h6 class="card-title">Device Information</h6>
            </div>
            <div class="card-body">
                <form asp-action="Create" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3" style="font-size:0.8rem;"></div>

                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label asp-for="Name" class="form-label">Device Name <span style="color:var(--color-danger);">*</span></label>
                            <input asp-for="Name" class="form-control" placeholder="e.g. Core Router 01" />
                            <span asp-validation-for="Name" class="text-danger" style="font-size:0.75rem;"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Hostname" class="form-label">Hostname</label>
                            <input asp-for="Hostname" class="form-control font-mono" placeholder="e.g. core-r01.local" />
                        </div>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label asp-for="IPAddress" class="form-label">IP Address <span style="color:var(--color-danger);">*</span></label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fa-solid fa-network-wired"></i></span>
                                <input asp-for="IPAddress" class="form-control font-mono" placeholder="e.g. 192.168.1.1" />
                            </div>
                            <span asp-validation-for="IPAddress" class="text-danger" style="font-size:0.75rem;"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="MacAddress" class="form-label">MAC Address</label>
                            <input asp-for="MacAddress" class="form-control font-mono" placeholder="e.g. 00:1A:2B:3C:4D:5E" />
                        </div>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label asp-for="DeviceTypeId" class="form-label">Device Type <span style="color:var(--color-danger);">*</span></label>
                            <select asp-for="DeviceTypeId" class="form-select" required>
                                <option value="">— Select type —</option>
                                @foreach (var t in types)
                                {
                                    <option value="@t.Id">@t.Name</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="StatusId" class="form-label">Initial Status <span style="color:var(--color-danger);">*</span></label>
                            <select asp-for="StatusId" class="form-select" required>
                                <option value="">— Select status —</option>
                                @foreach (var s in statuses)
                                {
                                    <option value="@s.Id">@s.Name</option>
                                }
                            </select>
                        </div>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label asp-for="Vendor" class="form-label">Vendor</label>
                            <input asp-for="Vendor" class="form-control" placeholder="e.g. Cisco, HP, Dell" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Model" class="form-label">Model</label>
                            <input asp-for="Model" class="form-control" placeholder="e.g. Catalyst 9300" />
                        </div>
                    </div>

                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <label asp-for="Location" class="form-label">Location</label>
                            <input asp-for="Location" class="form-control" placeholder="e.g. Server Room A, Rack 1" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Department" class="form-label">Department</label>
                            <input asp-for="Department" class="form-control" placeholder="e.g. IT Operations" />
                        </div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="fa-solid fa-plus me-1"></i> Add Device
                        </button>
                        <a asp-action="Index" class="btn btn-outline-primary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
